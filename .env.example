# WhatsApp Configuration
WHATSAPP_API_VERSION=v18.0
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WEBHOOK_VERIFY_TOKEN=jimmyconnect_secret_token

# Selar Configuration
SELAR_API_KEY=your_selar_api_key
SELAR_API_URL=https://api.selar.co/v1
SELAR_SUBSCRIPTION_ID=your_subscription_id
SUBSCRIPTION_PRICE=2500

# Database Files
USERS_DATABASE_FILE=users_db.json
QA_DATABASE_FILE=qa_database.json

# Google Sheets
GOOGLE_SHEETS_ENABLED=true
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_SHEET_NAME=jimmyconnect_students
